---
---
<section class="hero-section hero-container">
  {/* Navbar */}
  <header class="hero-nav">
    <div style="display: flex; align-items: center; gap: 12px;">
      <img src="/logo.jpeg" alt="IEEE CS HKBK" class="hero-logo" />
      <div>
        <div style="font-family: Anton, sans-serif; font-size: 18px; letter-spacing: 2px; text-transform: uppercase; line-height: 1;">IEEE CSHKBK</div>
        <div style="font-size: 10px; letter-spacing: 3px; opacity: 0.5; font-weight: 600; text-transform: uppercase;">HKBKCE</div>
      </div>
    </div>
  </header>

  {/* Centre */}
  <div class="hero-centre">
    <div class="hero-eyebrow">IEEE Computer Society &middot; Student Chapter &middot; HKBK College of Engineering</div>
    <h1 class="hero-title text-display" style="overflow: hidden; text-align: center;">
      IEEE CSHKBK
    </h1>
    <p class="hero-tagline">
      Advancing Technology For Humanity &mdash;<br class="br-desktop" /> building the next generation of innovators at HKBK.
    </p>
  </div>

  {/* Stats bar */}
  <div class="hero-stats-bar">
    <div class="hero-stat">
      <div style="font-family: Anton, sans-serif; font-size: 22px; letter-spacing: 1px;">2026</div>
      <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5; font-weight: 600; margin-top: 2px;">Founded</div>
    </div>
    <div class="hero-stat">
      <div style="font-family: Anton, sans-serif; font-size: 22px; letter-spacing: 1px;">50+</div>
      <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5; font-weight: 600; margin-top: 2px;">Members</div>
    </div>
    <div class="hero-stat">
      <div style="font-family: Anton, sans-serif; font-size: 22px; letter-spacing: 1px;">7+</div>
      <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5; font-weight: 600; margin-top: 2px;">Events Planned</div>
    </div>
    <div class="hero-stat">
      <div style="font-family: Anton, sans-serif; font-size: 22px; letter-spacing: 1px;">Bengaluru</div>
      <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.5; font-weight: 600; margin-top: 2px;">Location</div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  
  window.initHero = function(container = document) {
    const containers = container.querySelectorAll('.hero-container');
    containers.forEach(c => {
      const title = c.querySelector('.hero-title');
      if (!title || title.dataset.initialized) return;
      
      const text = title.innerText;
      title.innerHTML = '';
      text.split('').forEach(char => {
        const span = document.createElement('span');
        if (char === ' ') { 
          span.innerHTML = ' '; 
          span.className = 'split-char mobile-break'; 
        } else { 
          span.innerText = char; 
          span.className = 'split-char';
        }
        span.style.cssText = 'display:inline-block;transform:translateY(105%);opacity:0;will-change:transform';
        title.appendChild(span);
      });
      title.dataset.initialized = "true";

      const ctx = gsap.context(() => {
        gsap.to(c.querySelectorAll('.split-char'), { y: '0%', opacity: 1, duration: 1.2, stagger: 0.04, ease: 'power4.out', delay: 0.6 });
        gsap.fromTo(c.querySelectorAll('.hero-tagline'), { y: 22, opacity: 0 }, { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 1.3 });
        gsap.fromTo(c.querySelectorAll('.hero-stat'), { y: 10, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6, stagger: 0.08, ease: 'power3.out', delay: 1.8 });
      });
    });
  }
</script>
