---
---
<section id="about" class="about-section about-container" style="background-color: var(--color-bg); position: relative; z-index: 20;">
  <div style="max-width: 1200px; margin: 0 auto; width: 100%;">
    {/* Summary */}
    <div class="ab-fade" style="margin-bottom: 5rem;">
      <div class="section-label">About Us</div>
      <h2 class="section-title">ABOUT<br />IEEE CS</h2>
      <p style="margin-top: 1.25rem; max-width: 580px; font-size: 1.05rem; line-height: 1.7; opacity: 0.65; font-weight: 500;">
        The IEEE Computer Society Student Chapter at HKBK College of Engineering brings the global IEEE network to campus &mdash; providing opportunities for learning, networking, and professional development.
      </p>
    </div>

    {/* Global Stats */}
    <div class="about-stats ab-fade" style="margin-bottom: 6rem;">
      <div class="about-stat-box">
        <div style="font-family: Anton,sans-serif; font-size: 3.2rem; line-height: 1; margin-bottom: 0.4rem;">1946</div>
        <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; margin-bottom: 0.3rem;">Founded</div>
        <div style="font-size: 12px; opacity: 0.45;">Over 75 years advancing computing</div>
      </div>
      <div class="about-stat-box">
        <div style="font-family: Anton,sans-serif; font-size: 3.2rem; line-height: 1; margin-bottom: 0.4rem;">60K+</div>
        <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; margin-bottom: 0.3rem;">Global Members</div>
        <div style="font-size: 12px; opacity: 0.45;">Computing professionals worldwide</div>
      </div>
      <div class="about-stat-box">
        <div style="font-family: Anton,sans-serif; font-size: 3.2rem; line-height: 1; margin-bottom: 0.4rem;">100+</div>
        <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; margin-bottom: 0.3rem;">Publications</div>
        <div style="font-size: 12px; opacity: 0.45;">Journals and conference proceedings</div>
      </div>
    </div>

    {/* Mission & Vision */}
    <div class="about-grid-2 ab-fade" style="margin-bottom: 6rem;">
      <div class="about-mission">
        <div class="section-label" style="color: var(--color-bg); opacity: 0.4;">Mission</div>
        <h3 style="font-family: Anton,sans-serif; font-size: 2.2rem; text-transform: uppercase; line-height: 1; color: var(--color-bg); margin-bottom: 1.5rem;">OUR MISSION</h3>
        <p style="font-size: 14px; line-height: 1.8; opacity: 0.65; color: var(--color-bg); margin-bottom: 1.75rem;">
          To foster technical excellence and innovation through collaborative learning, hands-on workshops, and exposure to cutting-edge technologies.
        </p>
        <div style="display: flex; gap: 10px; margin-bottom: 0.6rem; font-size: 13px; line-height: 1.5; color: var(--color-bg); opacity: 0.65;">
          <span style="color: var(--color-accent); flex-shrink: 0;">&rarr;</span><span>Provide platforms for students to explore emerging technologies</span>
        </div>
        <div style="display: flex; gap: 10px; margin-bottom: 0.6rem; font-size: 13px; line-height: 1.5; color: var(--color-bg); opacity: 0.65;">
          <span style="color: var(--color-accent); flex-shrink: 0;">&rarr;</span><span>Facilitate knowledge sharing through workshops and seminars</span>
        </div>
        <div style="display: flex; gap: 10px; margin-bottom: 0.6rem; font-size: 13px; line-height: 1.5; color: var(--color-bg); opacity: 0.65;">
          <span style="color: var(--color-accent); flex-shrink: 0;">&rarr;</span><span>Connect students with industry professionals and mentors</span>
        </div>
        <div style="display: flex; gap: 10px; margin-bottom: 0.6rem; font-size: 13px; line-height: 1.5; color: var(--color-bg); opacity: 0.65;">
          <span style="color: var(--color-accent); flex-shrink: 0;">&rarr;</span><span>Organise hackathons and competitions to showcase skills</span>
        </div>
        <div style="display: flex; gap: 10px; margin-bottom: 0.6rem; font-size: 13px; line-height: 1.5; color: var(--color-bg); opacity: 0.65;">
          <span style="color: var(--color-accent); flex-shrink: 0;">&rarr;</span><span>Build a supportive community of tech enthusiasts</span>
        </div>
      </div>
      <div class="about-vision">
        <div class="about-vision-card" style="background-color: var(--color-green);">
          <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: white; opacity: 0.65; margin-bottom: 0.75rem;">Short-Term Vision</div>
          <p style="font-size: 14px; line-height: 1.75; color: white; opacity: 0.9;">
            Establish a vibrant campus community where every CS student has access to resources, mentorship, and opportunities to grow technically and professionally.
          </p>
        </div>
        <div class="about-vision-card" style="background-color: var(--color-accent);">
          <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: white; opacity: 0.65; margin-bottom: 0.75rem;">Long-Term Vision</div>
          <p style="font-size: 14px; line-height: 1.75; color: white; opacity: 0.9;">
            Be the leading student organisation empowering the next generation of technology leaders through excellence in education, innovation, and community engagement.
          </p>
        </div>
      </div>
    </div>

    {/* Connect */}
    <div class="ab-fade">
      <div class="section-label">Connect</div>
      <h3 class="section-title" style="margin-bottom: 3rem;">MEMBERSHIP & COMMUNITY</h3>
      <div class="about-grid-2">
        <a href="https://www.ieee.org/membership" target="_blank" rel="noopener noreferrer" class="interactive about-quick-link">
          <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; opacity: 0.45; margin-bottom: 0.75rem;">Membership</div>
          <div style="font-family: Anton,sans-serif; font-size: clamp(1.8rem,3vw,3rem); text-transform: uppercase; line-height: 1; margin-bottom: 1rem;">Join IEEE Membership</div>
          <p style="font-size: 14px; line-height: 1.75; opacity: 0.6; max-width: 28rem;">Become an IEEE member to access global resources, networks, and opportunities beyond the campus chapter.</p>
          <span style="margin-top: 1.5rem; display: inline-flex; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700;">Open Link &nearr;</span>
        </a>
        <a href="https://chat.whatsapp.com/L4U5kjfKBJK1XgJclrUJNA" target="_blank" rel="noopener noreferrer" class="interactive about-quick-link">
          <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; opacity: 0.45; margin-bottom: 0.75rem;">Community</div>
          <div style="font-family: Anton,sans-serif; font-size: clamp(1.8rem,3vw,3rem); text-transform: uppercase; line-height: 1; margin-bottom: 1rem;">WhatsApp Community</div>
          <p style="font-size: 14px; line-height: 1.75; opacity: 0.6; max-width: 28rem;">Join the chapter community to stay updated about events, announcements, registrations, and chapter activity.</p>
          <span style="margin-top: 1.5rem; display: inline-flex; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700;">Open Link &nearr;</span>
        </a>
      </div>
    </div>
  </div>
</section>
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  window.initAbout = function(container = document) {
    if (!container) return;
    const containers = container.querySelectorAll('.about-container');
    containers.forEach(c => {
      gsap.fromTo(c.querySelectorAll('.ab-fade'), { y: 40, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, stagger: 0.12, ease: 'power3.out', scrollTrigger: { trigger: c, start: 'top 72%' } });
    });
  }
</script>
