---
---

<footer class="footer-section" style="background-color: var(--color-black); color: var(--color-bg); padding: 5rem 4rem 3rem; margin-top: auto;">
  <div style="max-width: 1200px; margin: 0 auto; width: 100%;">
    <div class="footer-grid">
      
      {/* Brand */}
      <div>
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 2rem;">
          <img src="/logo.jpeg" alt="IEEE CS HKBK Logo" style="width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(241,239,235,0.12);" onerror="this.style.display='none'" />
          <div>
            <div style="font-family: Anton,sans-serif; font-size: 18px; letter-spacing: 2px; text-transform: uppercase; line-height: 1;">IEEE CSHKBK</div>
            <div style="font-size: 10px; letter-spacing: 3px; opacity: 0.45; font-weight: 600; text-transform: uppercase;">HKBKCE</div>
          </div>
        </div>
        <p style="font-size: 13px; line-height: 1.7; opacity: 0.6; max-width: 260px;">
          Empowering the next generation of computing professionals at HKBK College of Engineering. Advancing technology for humanity.
        </p>
      </div>

      {/* Links */}
      <div>
        <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: var(--color-accent); margin-bottom: 1.5rem;">Explore</div>
        <div style="display: flex; flex-direction: column; gap: 12px;">
          <a href="/events" class="interactive" style="font-size: 14px; opacity: 0.7; width: fit-content; transition: opacity 0.2s;" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=0.7">Events</a>
          <a href="/about" class="interactive" style="font-size: 14px; opacity: 0.7; width: fit-content; transition: opacity 0.2s;" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=0.7">About Us</a>
          <a href="/team" class="interactive" style="font-size: 14px; opacity: 0.7; width: fit-content; transition: opacity 0.2s;" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=0.7">Our Team</a>
          <a href="/achievements" class="interactive" style="font-size: 14px; opacity: 0.7; width: fit-content; transition: opacity 0.2s;" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=0.7">Achievements</a>
        </div>
      </div>

      {/* Connect */}
      <div>
        <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; color: var(--color-accent); margin-bottom: 1.5rem;">Connect</div>
        <div style="display: flex; flex-direction: column; gap: 12px;">
          <a href="https://instagram.com/ieeesb.hkbkce" target="_blank" rel="noopener noreferrer" class="interactive" style="font-size: 14px; opacity: 0.7; width: fit-content; transition: opacity 0.2s;" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=0.7">Instagram &nearr;</a>
          <a href="https://linkedin.com/company/ieee-student-branch-hkbkce" target="_blank" rel="noopener noreferrer" class="interactive" style="font-size: 14px; opacity: 0.7; width: fit-content; transition: opacity 0.2s;" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=0.7">LinkedIn &nearr;</a>
          <a href="mailto:ieeecshkbk@gmail.com" class="interactive" style="font-size: 14px; opacity: 0.7; width: fit-content; transition: opacity 0.2s;" onmouseenter="this.style.opacity=1" onmouseleave="this.style.opacity=0.7">Email Us &nearr;</a>
        </div>
      </div>
      
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(241,239,235,0.1); margin-top: 4rem; padding-top: 2rem; font-size: 11px; opacity: 0.4; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;">
      <div>&copy; 2026 IEEE CS HKBKCE</div>
      <div style="display: flex; gap: 1.5rem;">
        <span>Built by <a href="#" style="color: var(--color-bg); border-bottom: 1px solid currentColor;">Abdul Muqeet</a></span>
      </div>
    </div>
  </div>
</footer>
